# Local API server port for local-only processing.
LOCAL_API_PORT=5174

# Vite proxy target for /api calls.
LOCAL_API_PROXY_TARGET="http://127.0.0.1:5174"

# Python interpreter used for local transcription script.
# Use a project virtualenv for reproducible local dependencies.
PYTHON_BIN=".venv/bin/python"

# Local Whisper configuration (used by scripts/transcribe.py).
WHISPER_MODEL="small"
WHISPER_DEVICE="cuda"
WHISPER_COMPUTE_TYPE="float16"
WHISPER_LANGUAGE="en"
DOUBLE_TAP_WINDOW="0.35"
SILENCE_THRESHOLD="0.02"
SILENCE_SECONDS="1.0"
MIN_RECORD_SECONDS="0.8"
MAX_RECORD_SECONDS="45"
TYPE_DELAY_MS="1"
SAMPLE_RATE="16000"
CHANNELS="1"
BLOCK_MS="50"
LOG_LEVEL="INFO"

# Optional local text refinement with Ollama.
# If Ollama is not running, the app falls back to raw transcription output.
OLLAMA_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="llama3.2:3b"
